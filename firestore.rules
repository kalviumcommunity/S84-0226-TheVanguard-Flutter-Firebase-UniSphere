  rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─────────────────────────────────────────────────────────────────────────
    // Helper Functions
    // ─────────────────────────────────────────────────────────────────────────
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        getUserData().role in ['clubAdmin', 'superAdmin'];
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superAdmin';
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Users Collection
    // ─────────────────────────────────────────────────────────────────────────
    
    match /users/{userId} {
      // Users can read their own profile
      // Admins can read any profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile on signup
      allow create: if isOwner(userId);
      
      // Users can update their own profile (except role)
      // Only superAdmin can change roles
      allow update: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) 
        || isSuperAdmin();
      
      // Only superAdmin can delete users
      allow delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Events Collection
    // ─────────────────────────────────────────────────────────────────────────
    
    match /events/{eventId} {
      // Anyone authenticated can read events
      allow read: if isAuthenticated();
      
      // Only admins can create events
      allow create: if isAdmin();
      
      // Only admins can update events
      // Registration count updates are allowed via registration process
      allow update: if isAdmin() || 
        (isAuthenticated() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['registeredCount']));
      
      // Only admins can delete events
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Announcements Collection
    // ─────────────────────────────────────────────────────────────────────────
    
    match /announcements/{announcementId} {
      // Anyone authenticated can read announcements
      allow read: if isAuthenticated();
      
      // Only admins can create announcements
      allow create: if isAdmin();
      
      // Only admins can update announcements
      allow update: if isAdmin();
      
      // Only admins can delete announcements
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Registrations Collection
    // ─────────────────────────────────────────────────────────────────────────
    
    match /registrations/{registrationId} {
      // Users can read their own registrations
      // Admins can read all registrations
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can create their own registrations
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // Users can update (cancel) their own registrations
      // Admins can update any registration
      allow update: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Only admins can delete registrations
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Attendance Collection
    // ─────────────────────────────────────────────────────────────────────────
    
    match /attendance/{attendanceId} {
      // Users can read their own attendance
      // Admins can read all attendance
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || isAdmin());
      
      // Users can create their own attendance (check-in)
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // Only admins can update attendance records (corrections)
      allow update: if isAdmin();
      
      // Only admins can delete attendance records
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────────────
    // Clubs Collection (for future use)
    // ─────────────────────────────────────────────────────────────────────────
    
    match /clubs/{clubId} {
      // Anyone authenticated can read clubs
      allow read: if isAuthenticated();
      
      // Only superAdmin can create clubs
      allow create: if isSuperAdmin();
      
      // Club admins can update their own clubs
      // SuperAdmin can update any club
      allow update: if isSuperAdmin() || 
        (isAdmin() && request.auth.uid in resource.data.adminIds);
      
      // Only superAdmin can delete clubs
      allow delete: if isSuperAdmin();
    }
  }
}
